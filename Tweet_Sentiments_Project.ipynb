    {
      "cell_type": "markdown",
      "metadata": {
        "id": "ieEd092RdYY1"
      },
      "source": [
        "# Preprocessing of data\n",
        "Emoji\n",
        "Hashtag\n",
        "@content\n",
        "other than words\n",
        "extra spaces\n",
        "Non English Words\n",
        "Special characters\n",
        "Links   (https://, www.)\n",
        "capital letter, Lower letters (Specific 1)\n",
        "Null values\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "dOh08N7ldacp"
      },
      "source": [
        "# Checking the Null values and removing it\n",
        "if OrgData.isnull().values.any():\n",
        "  OrgData.dropna()\n",
        "  print(\"Null Values Found and dropped\")\n",
        "else:\n",
        "  print(\"No Null Value Found\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "Lx6zouibhDAJ"
      },
      "source": [
        "# Converting all tweets to lower case\n",
        "OrgData['tweets_lwr']=OrgData['tweets'].str.lower()\n",
        "print(OrgData)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "fWFudww_kArx"
      },
      "source": [
        "# removing Links from the string\n",
        "\n",
        "# https://www.helloworld.com\n",
        "\n",
        "import re\n",
        "print(OrgData[\"tweets_lwr\"].str.find(\"http\"))\n",
        "\n",
        "TmpLst=[]\n",
        "for temp in OrgData[\"tweets_lwr\"]:\n",
        "  TmpLst.append(re.sub('https://\\S+|www\\.\\S+|http:?//\\S+','',temp))\n",
        "\n",
        "OrgData[\"tweets_NoLink\"] = TmpLst\n",
        "\n",
        "print(OrgData[\"tweets_NoLink\"].str.find(\"http\"))\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "z703lhF11TrH"
      },
      "source": [
        "# deteting Tags start with @\n",
        "TmpLst=[]\n",
        "for temp in OrgData[\"tweets_NoLink\"]:\n",
        "  TmpLst.append(re.sub('@[A-Za-z0-9]+','',temp))\n",
        "\n",
        "OrgData[\"tweets_NoTag\"] = TmpLst\n",
        "\n",
        "print(OrgData[\"tweets_NoTag\"])"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "U4RNOVzg2M0v"
      },
      "source": [
        "# deteting white space or tab\n",
        "TmpLst=[]\n",
        "for temp in OrgData[\"tweets_NoTag\"]:\n",
        "  TmpLst.append(re.sub('^\\w\\s','',temp))\n",
        "\n",
        "OrgData[\"tweets_NoWtSpaceTab\"] = TmpLst\n",
        "\n",
        "print(OrgData[\"tweets_NoWtSpaceTab\"])"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "A6ZvLLdJ4vjd"
      },
      "source": [
        "# Removing flags, emogis, etc using unicode\n",
        "TmpLst=[]\n",
        "for temp in OrgData[\"tweets_NoWtSpaceTab\"]:\n",
        "  TmpLst.append(re.sub('['\n",
        "                                 u'\\U0001F600-\\U0001F64F'  # emoticons\n",
        "                                 u'\\U0001F300-\\U0001F5FF'  # symbols & pictographs\n",
        "                                 u'\\U0001F680-\\U0001F6FF'  # transport & map symbols\n",
        "                                 u'\\U0001F1E0-\\U0001F1FF'  # flags\n",
        "                                 u'\\U00002702-\\U000027B0'\n",
        "                                 u'\\U000024C2-\\U0001F251'\n",
        "                                 ']+','',temp))\n",
        "\n",
        "OrgData[\"tweets_NoEmoEtc\"] = TmpLst\n",
        "\n",
        "print(OrgData[\"tweets_NoEmoEtc\"])\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "m1hwcpe17_Y8"
      },
      "source": [
        "# How to write the new refined data in a excel\n",
